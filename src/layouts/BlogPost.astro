---
interface Props {
  title: string;
  date: Date;
  description?: string;
}

const { title, date, description } = Astro.props;
const formatted = date.toLocaleDateString("en-GB", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Mörgæsis</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Mörgæsis"
      href="/rss.xml"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif&family=DM+Sans:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <main>
      <nav class="back">
        <a href="/blog">&larr; blog</a>
      </nav>

      <article>
        <header>
          <h1>{title}</h1>
          <time datetime={date.toISOString()}>{formatted}</time>
        </header>
        <div class="prose">
          <slot />
        </div>
      </article>
    </main>

    <style>
      :root {
        --cream: #f5f0e8;
        --ink: #1a1714;
        --mid: #6b6259;
        --faint: #c8bfb2;
        --rule: #d9d0c3;
        --amber: #c97b3a;
        --teal: #3f8f8a;
        --moss: #6f8d51;
        --rose: #bf5f5a;
        --paper: #eee8de;
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html {
        font-size: 18px;
      }

      body {
        font-family: "DM Sans", sans-serif;
        font-weight: 400;
        background: var(--cream);
        color: var(--ink);
        line-height: 1.7;
        min-height: 100vh;
        padding: 0;
        -webkit-font-smoothing: antialiased;
      }

      main {
        max-width: 648px;
        margin: 0 auto;
        padding: 8vh clamp(0.5rem, 2vw, 0.8rem) 8vh;
      }

      .back {
        font-size: 0.82rem;
        margin-bottom: 3rem;
      }

      .back a {
        color: var(--faint);
        text-decoration: none;
        border-bottom: none;
        transition: color 0.2s;
      }

      .back a:hover {
        color: var(--ink);
      }

      article header {
        margin-bottom: 2.5rem;
      }

      h1 {
        font-family: "Instrument Serif", serif;
        font-weight: 400;
        font-size: 2.4rem;
        letter-spacing: 0;
        line-height: 1.15;
        margin-bottom: 0.5rem;
        overflow-wrap: anywhere;
        text-wrap: balance;
      }

      time {
        font-size: 0.78rem;
        color: var(--faint);
        letter-spacing: 0;
      }

      .prose :global(h2) {
        font-family: "Instrument Serif", serif;
        font-weight: 400;
        font-size: 1.5rem;
        margin-top: 2.5rem;
        margin-bottom: 0.8rem;
      }

      .prose :global(h3) {
        font-family: "DM Sans", sans-serif;
        font-weight: 500;
        font-size: 1rem;
        margin-top: 2rem;
        margin-bottom: 0.6rem;
      }

      .prose :global(p) {
        margin-bottom: 1.2rem;
        color: var(--ink);
      }

      .prose {
        overflow-wrap: break-word;
      }

      .prose::after {
        clear: both;
        content: "";
        display: block;
      }

      .prose :global(a) {
        color: var(--ink);
        text-decoration: none;
        border-bottom: 1.5px solid var(--rule);
        transition: border-color 0.2s;
        overflow-wrap: anywhere;
      }

      .prose :global(a:hover) {
        border-bottom-color: var(--ink);
      }

      .prose :global(sup) {
        line-height: 0;
      }

      .prose :global(a[data-footnote-ref]) {
        align-items: center;
        border: 1px solid var(--rule);
        border-radius: 999px;
        display: inline-flex;
        font-size: 0.6em;
        font-variant-numeric: tabular-nums;
        font-weight: 500;
        justify-content: center;
        letter-spacing: 0;
        line-height: 1.35;
        margin: 0 0.14em;
        min-width: 1.55em;
        padding: 0.02em 0.5em;
        transform: translateY(-0.08em);
        vertical-align: super;
      }

      .prose :global(ul),
      .prose :global(ol) {
        margin-bottom: 1.2rem;
        padding-left: 1.2rem;
      }

      .prose :global(li) {
        margin-bottom: 0.4rem;
      }

      .prose :global(blockquote) {
        border-left: 3px solid var(--amber);
        padding-left: 1rem;
        margin: 1.5rem 0;
        color: var(--mid);
        font-style: italic;
      }

      .prose :global(code) {
        font-size: 0.88em;
        background: #e8e3db;
        padding: 0.15em 0.4em;
        border-radius: 3px;
        overflow-wrap: anywhere;
      }

      .prose :global(pre) {
        background: var(--ink);
        color: var(--cream);
        padding: 1.2rem;
        border-radius: 6px;
        overflow-x: auto;
        margin-bottom: 1.5rem;
        font-size: 0.85rem;
        line-height: 1.5;
      }

      .prose :global(pre code) {
        background: none;
        padding: 0;
        border-radius: 0;
      }

      .prose :global(hr) {
        border: none;
        border-top: 1px solid var(--rule);
        margin: 2rem 0;
      }

      .prose :global(.article-figure) {
        border-bottom: 1px solid var(--rule);
        border-top: 1px solid var(--rule);
        margin: 2.2rem 0;
        padding: 1rem 0;
      }

      .prose :global(.article-figure figcaption) {
        color: var(--mid);
        font-size: 0.74rem;
        font-weight: 500;
        letter-spacing: 0;
        margin-bottom: 0.85rem;
        text-transform: uppercase;
      }

      .prose :global(.sketch-figure) {
        margin-left: 50%;
        transform: translateX(-50%);
        width: min(760px, calc(100vw - 1rem));
      }

      .prose :global(.sketch-figure img) {
        aspect-ratio: auto 1200 / 800;
        border: 1px solid var(--rule);
        border-radius: 4px;
        display: block;
        height: auto;
        margin: 0;
        object-fit: contain;
        width: 100%;
      }

      .prose :global(.gate-stage) {
        background: linear-gradient(135deg, #f5efe4, #e7ddcf);
        border: 1px solid var(--rule);
        cursor: crosshair;
        outline: none;
        overflow: hidden;
        position: relative;
        touch-action: manipulation;
      }

      .prose :global(.gate-stage:focus-visible) {
        box-shadow: 0 0 0 3px rgba(63, 143, 138, 0.24);
      }

      .prose :global(.gate-map) {
        display: block;
        min-height: 18rem;
        width: 100%;
      }

      .prose :global(.gate-map text),
      .prose :global(.consequence-map text) {
        fill: var(--mid);
        font-family: "DM Sans", sans-serif;
        font-size: 14px;
        font-weight: 500;
        text-transform: uppercase;
      }

      .prose :global(.gate-floor) {
        fill: url(#gate-floor-gradient);
      }

      .prose :global(.gate-lane) {
        fill: none;
        stroke-linecap: round;
        stroke-width: 9;
        opacity: 0.26;
        transition:
          opacity 0.2s ease,
          stroke-width 0.2s ease;
      }

      .prose :global(.lane-approach) {
        stroke: rgba(26, 23, 20, 0.28);
      }

      .prose :global(.lane-plan) {
        stroke: url(#predict-gradient);
      }

      .prose :global(.lane-canary) {
        stroke: url(#contain-gradient);
      }

      .prose :global(.lane-abort) {
        stroke: url(#abort-gradient);
      }

      .prose :global(.gate-stage[data-route="plan"] .lane-plan),
      .prose :global(.gate-stage[data-route="canary"] .lane-canary),
      .prose :global(.gate-stage[data-route="abort"] .lane-abort) {
        opacity: 1;
        stroke-width: 13;
      }

      .prose :global(.gate-trail) {
        fill: none;
        opacity: 0.8;
        stroke: var(--teal);
        stroke-linecap: round;
        stroke-width: 4;
      }

      .prose :global(.gate-stage[data-route="canary"] .gate-trail) {
        stroke: var(--amber);
      }

      .prose :global(.gate-stage[data-route="abort"] .gate-trail) {
        stroke: var(--rose);
      }

      .prose :global(.gate-meter rect:first-of-type),
      .prose :global(.gate-meter rect:nth-of-type(3)) {
        fill: rgba(26, 23, 20, 0.1);
      }

      .prose :global([data-coverage-fill]) {
        fill: var(--teal);
        transition: width 0.18s ease;
      }

      .prose :global([data-blast-fill]) {
        fill: var(--amber);
        transition:
          fill 0.18s ease,
          width 0.18s ease;
      }

      .prose :global(.gate-stage[data-route="abort"] [data-blast-fill]) {
        fill: var(--rose);
      }

      .prose :global(.consequence-gate) {
        transform-box: fill-box;
        transform-origin: center;
        transition: transform 0.18s ease;
      }

      .prose :global(.gate-shadow) {
        fill: rgba(26, 23, 20, 0.08);
      }

      .prose :global(.gate-post),
      .prose :global(.gate-header) {
        fill: rgba(26, 23, 20, 0.62);
      }

      .prose :global(.gate-door rect) {
        fill: rgba(245, 240, 232, 0.96);
        stroke: rgba(26, 23, 20, 0.42);
        stroke-width: 2;
      }

      .prose :global(.gate-door path) {
        stroke: rgba(26, 23, 20, 0.28);
        stroke-linecap: round;
        stroke-width: 2;
      }

      .prose :global(.gate-door) {
        transform-box: fill-box;
        transform-origin: center;
        transition: transform 0.18s ease;
      }

      .prose :global(.gate-stage[data-route="plan"] [data-gate-door-left]) {
        transform: translateX(-18px) rotate(-8deg);
      }

      .prose :global(.gate-stage[data-route="plan"] [data-gate-door-right]) {
        transform: translateX(18px) rotate(8deg);
      }

      .prose :global(.gate-stage[data-route="canary"] [data-gate-door-left]) {
        transform: translateX(-7px);
      }

      .prose :global(.gate-stage[data-route="canary"] [data-gate-door-right]) {
        transform: translateX(7px);
      }

      .prose :global(.gate-lock) {
        opacity: 0;
        transition:
          opacity 0.18s ease,
          transform 0.18s ease;
        transform: translateY(-6px);
      }

      .prose :global(.gate-lock path),
      .prose :global(.gate-lock rect) {
        fill: rgba(245, 240, 232, 0.94);
        stroke: rgba(26, 23, 20, 0.58);
        stroke-linecap: round;
        stroke-linejoin: round;
        stroke-width: 3;
      }

      .prose :global(.gate-lock circle) {
        fill: rgba(26, 23, 20, 0.58);
      }

      .prose :global(.gate-stage[data-route="abort"] .gate-lock) {
        opacity: 1;
        transform: translateY(0);
      }

      .prose :global(.gate-arm rect) {
        fill: var(--rose);
        opacity: 0;
        transform-box: fill-box;
        transform-origin: left center;
        transition:
          opacity 0.18s ease,
          transform 0.18s ease;
        transform: rotate(-16deg);
      }

      .prose :global(.gate-arm circle) {
        fill: rgba(26, 23, 20, 0.44);
        opacity: 0;
        transition: opacity 0.18s ease;
      }

      .prose :global(.gate-stage[data-route="abort"] .gate-arm rect),
      .prose :global(.gate-stage[data-route="abort"] .gate-arm circle) {
        opacity: 1;
        transform: rotate(0deg);
      }

      .prose :global(.target-prod rect),
      .prose :global(.target-canary rect),
      .prose :global(.target-stop rect) {
        fill: rgba(245, 240, 232, 0.88);
        stroke: rgba(26, 23, 20, 0.32);
        stroke-width: 2;
      }

      .prose :global(.target-prod path),
      .prose :global(.target-canary path),
      .prose :global(.target-stop path) {
        fill: none;
        stroke: rgba(26, 23, 20, 0.5);
        stroke-linecap: round;
        stroke-linejoin: round;
        stroke-width: 3;
      }

      .prose :global(.target-prod circle),
      .prose :global(.target-canary circle) {
        fill: var(--teal);
      }

      .prose :global(.target-canary circle) {
        fill: var(--amber);
      }

      .prose :global(.target-stop path) {
        stroke: var(--rose);
      }

      .prose :global(.gate-stage[data-route="plan"] .target-prod rect),
      .prose :global(.gate-stage[data-route="canary"] .target-canary rect),
      .prose :global(.gate-stage[data-route="abort"] .target-stop rect) {
        stroke-width: 3;
        filter: drop-shadow(0 0 8px rgba(63, 143, 138, 0.16));
      }

      .prose :global(.gate-cursor-target path) {
        fill: rgba(26, 23, 20, 0.1);
        stroke: rgba(26, 23, 20, 0.24);
        stroke-linecap: round;
        stroke-linejoin: round;
        stroke-width: 2;
      }

      .prose :global(.gate-pulse) {
        fill: var(--amber);
        pointer-events: none;
        transition:
          fill 0.18s ease,
          r 0.18s ease;
      }

      .prose :global(.gate-stage[data-route="plan"] .gate-pulse) {
        fill: var(--teal);
      }

      .prose :global(.gate-stage[data-route="abort"] .gate-pulse) {
        fill: var(--rose);
      }

      .prose :global(.gate-pulse-ring) {
        fill: none;
        pointer-events: none;
        stroke: rgba(201, 123, 58, 0.48);
        stroke-width: 2;
        transform-origin: center;
      }

      .prose :global(.gate-stage[data-route="plan"] .gate-pulse-ring) {
        stroke: rgba(63, 143, 138, 0.5);
      }

      .prose :global(.gate-stage[data-route="abort"] .gate-pulse-ring) {
        stroke: rgba(191, 95, 90, 0.6);
      }

      .prose :global(.gate-status) {
        background: rgba(245, 240, 232, 0.82);
        border-top: 1px solid var(--rule);
        color: var(--mid);
        font-size: 0.78rem;
        line-height: 1.35;
        margin: 0;
        padding: 0.65rem 0.8rem;
      }

      .prose :global(.consequence-stage) {
        background: linear-gradient(135deg, #f4ede3, #e8dfd2);
        border: 1px solid var(--rule);
        cursor: ew-resize;
        outline: none;
        overflow: hidden;
        position: relative;
        touch-action: manipulation;
      }

      .prose :global(.consequence-stage:focus-visible) {
        box-shadow: 0 0 0 3px rgba(201, 123, 58, 0.24);
      }

      .prose :global(.consequence-map) {
        display: block;
        min-height: 17rem;
        width: 100%;
      }

      .prose :global(.consequence-track) {
        fill: none;
        stroke: rgba(26, 23, 20, 0.18);
        stroke-linecap: round;
        stroke-width: 9;
      }

      .prose :global(.consequence-lane) {
        opacity: 0.64;
        transition:
          opacity 0.18s ease,
          transform 0.18s ease;
      }

      .prose :global(.consequence-stage[data-level="local"] .lane-local),
      .prose :global(.consequence-stage[data-level="reversible"] .lane-reversible),
      .prose :global(.consequence-stage[data-level="disruptive"] .lane-disruptive),
      .prose :global(.consequence-stage[data-level="irreversible"] .lane-irreversible) {
        opacity: 1;
        transform: translateY(-3px);
      }

      .prose :global(.turnstile),
      .prose :global(.gate-pass),
      .prose :global(.half-gate),
      .prose :global(.revert-arrow),
      .prose :global(.warning-bars),
      .prose :global(.blast-brace),
      .prose :global(.blast-lock) {
        fill: none;
        stroke: rgba(26, 23, 20, 0.48);
        stroke-linecap: round;
        stroke-linejoin: round;
        stroke-width: 4;
      }

      .prose :global(.lane-local .turnstile),
      .prose :global(.lane-local .gate-pass) {
        stroke: var(--teal);
      }

      .prose :global(.lane-reversible .gate-frame),
      .prose :global(.lane-disruptive .gate-frame),
      .prose :global(.blast-door) {
        fill: rgba(245, 240, 232, 0.88);
        stroke: rgba(26, 23, 20, 0.42);
        stroke-width: 3;
      }

      .prose :global(.lane-reversible .half-gate),
      .prose :global(.lane-reversible .revert-arrow) {
        stroke: var(--amber);
      }

      .prose :global(.lane-disruptive .heavy) {
        stroke: var(--rose);
      }

      .prose :global(.warning-bars) {
        stroke: rgba(191, 95, 90, 0.58);
      }

      .prose :global(.warning-light) {
        fill: var(--amber);
      }

      .prose :global(.blast-door) {
        fill: rgba(191, 95, 90, 0.14);
        stroke: var(--rose);
      }

      .prose :global(.blast-lock) {
        stroke: var(--rose);
      }

      .prose :global(.consequence-trail) {
        fill: none;
        stroke: var(--teal);
        stroke-linecap: round;
        stroke-width: 4;
      }

      .prose :global(.consequence-stage[data-level="reversible"] .consequence-trail) {
        stroke: var(--amber);
      }

      .prose :global(.consequence-stage[data-level="disruptive"] .consequence-trail),
      .prose :global(.consequence-stage[data-level="irreversible"] .consequence-trail) {
        stroke: var(--rose);
      }

      .prose :global(.consequence-token) {
        fill: var(--teal);
        transition: fill 0.18s ease;
      }

      .prose :global(.consequence-token-ring) {
        fill: none;
        stroke: rgba(63, 143, 138, 0.5);
        stroke-width: 2;
      }

      .prose :global(.consequence-stage[data-level="reversible"] .consequence-token) {
        fill: var(--amber);
      }

      .prose :global(.consequence-stage[data-level="reversible"] .consequence-token-ring) {
        stroke: rgba(201, 123, 58, 0.55);
      }

      .prose :global(.consequence-stage[data-level="disruptive"] .consequence-token),
      .prose :global(.consequence-stage[data-level="irreversible"] .consequence-token) {
        fill: var(--rose);
      }

      .prose :global(.consequence-stage[data-level="disruptive"] .consequence-token-ring),
      .prose :global(.consequence-stage[data-level="irreversible"] .consequence-token-ring) {
        stroke: rgba(191, 95, 90, 0.65);
      }

      .prose :global(.consequence-sparks) {
        opacity: 0;
        transition: opacity 0.18s ease;
      }

      .prose :global(.consequence-sparks path) {
        stroke: var(--rose);
        stroke-linecap: round;
        stroke-width: 4;
      }

      .prose :global(.consequence-stage[data-level="irreversible"] .consequence-sparks) {
        opacity: 1;
      }

      .prose :global(.consequence-status) {
        background: rgba(245, 240, 232, 0.82);
        border-top: 1px solid var(--rule);
        color: var(--mid);
        font-size: 0.78rem;
        line-height: 1.35;
        margin: 0;
        padding: 0.65rem 0.8rem;
      }

      .prose :global(.sand-stage) {
        background: linear-gradient(180deg, #efe8dc, #e9e1d4);
        border: 1px solid var(--rule);
        cursor: pointer;
        min-height: 20rem;
        overflow: hidden;
        position: relative;
        touch-action: manipulation;
      }

      .prose :global(.sand-stage:focus-visible) {
        box-shadow: 0 0 0 3px rgba(191, 95, 90, 0.24);
      }

      .prose :global(.sand-stage canvas) {
        display: block;
        height: auto;
        width: 100%;
      }

      .prose :global(.sand-hud) {
        color: rgba(26, 23, 20, 0.62);
        display: grid;
        font-size: 0.72rem;
        font-weight: 500;
        grid-template-columns: repeat(3, 1fr);
        left: 0;
        letter-spacing: 0;
        padding: 0.65rem 0.75rem;
        pointer-events: none;
        position: absolute;
        right: 0;
        text-transform: uppercase;
        top: 0;
      }

      .prose :global(.sand-hud span:nth-child(2)) {
        text-align: center;
      }

      .prose :global(.sand-hud span:nth-child(3)) {
        text-align: right;
      }

      .prose :global(.sand-mode) {
        align-items: center;
        background: rgba(245, 240, 232, 0.86);
        border-top: 1px solid rgba(217, 208, 195, 0.8);
        bottom: 0;
        color: var(--mid);
        display: flex;
        font-size: 0.68rem;
        left: 0;
        min-height: 2rem;
        opacity: 0.74;
        padding: 0.2rem 0.65rem;
        position: absolute;
        right: 0;
        text-transform: uppercase;
      }

      .prose :global(.sandbox-stage) {
        background: linear-gradient(180deg, #f1eadf, #e7ded0);
        border: 1px solid var(--rule);
        cursor: pointer;
        min-height: 20rem;
        overflow: hidden;
        position: relative;
        touch-action: manipulation;
      }

      .prose :global(.sandbox-stage:focus-visible) {
        box-shadow: 0 0 0 3px rgba(63, 143, 138, 0.24);
      }

      .prose :global(.sandbox-stage canvas) {
        display: block;
        height: auto;
        width: 100%;
      }

      .prose :global(.sandbox-hud) {
        color: rgba(26, 23, 20, 0.62);
        display: grid;
        font-size: 0.72rem;
        font-weight: 500;
        grid-template-columns: repeat(3, 1fr);
        left: 0;
        letter-spacing: 0;
        padding: 0.65rem 0.75rem;
        pointer-events: none;
        position: absolute;
        right: 0;
        text-transform: uppercase;
        top: 0;
      }

      .prose :global(.sandbox-hud span:nth-child(2)) {
        text-align: center;
      }

      .prose :global(.sandbox-hud span:nth-child(3)) {
        text-align: right;
      }

      .prose :global(.sandbox-mode) {
        align-items: center;
        background: rgba(245, 240, 232, 0.86);
        border-top: 1px solid rgba(217, 208, 195, 0.8);
        bottom: 0;
        color: var(--mid);
        display: flex;
        font-size: 0.68rem;
        left: 0;
        min-height: 2rem;
        opacity: 0.74;
        padding: 0.2rem 0.65rem;
        position: absolute;
        right: 0;
        text-transform: uppercase;
      }

      .prose :global(.footnotes) {
        border-top: 1px solid var(--rule);
        margin-top: 2rem;
        padding-top: 1rem;
        font-size: 0.82rem;
        color: var(--mid);
      }

      .prose :global(.footnotes p) {
        margin-bottom: 0.6rem;
      }

