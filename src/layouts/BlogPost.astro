---
interface Props {
  title: string;
  date: Date;
  description?: string;
}

const { title, date, description } = Astro.props;
const formatted = date.toLocaleDateString("en-GB", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Mörgæsis</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Mörgæsis"
      href="/rss.xml"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif&family=DM+Sans:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <main>
      <nav class="back">
        <a href="/blog">&larr; blog</a>
      </nav>

      <article>
        <header>
          <h1>{title}</h1>
          <time datetime={date.toISOString()}>{formatted}</time>
        </header>
        <div class="prose">
          <slot />
        </div>
      </article>
    </main>

    <style>
      :root {
        --cream: #f5f0e8;
        --ink: #1a1714;
        --mid: #6b6259;
        --faint: #c8bfb2;
        --rule: #d9d0c3;
        --amber: #c97b3a;
        --teal: #3f8f8a;
        --moss: #6f8d51;
        --rose: #bf5f5a;
        --paper: #eee8de;
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html {
        font-size: 18px;
      }

      body {
        font-family: "DM Sans", sans-serif;
        font-weight: 400;
        background: var(--cream);
        color: var(--ink);
        line-height: 1.7;
        min-height: 100vh;
        padding: 0;
        -webkit-font-smoothing: antialiased;
      }

      main {
        max-width: 648px;
        margin: 0 auto;
        padding: 8vh clamp(0.5rem, 2vw, 0.8rem) 8vh;
      }

      .back {
        font-size: 0.82rem;
        margin-bottom: 3rem;
      }

      .back a {
        color: var(--faint);
        text-decoration: none;
        border-bottom: none;
        transition: color 0.2s;
      }

      .back a:hover {
        color: var(--ink);
      }

      article header {
        margin-bottom: 2.5rem;
      }

      h1 {
        font-family: "Instrument Serif", serif;
        font-weight: 400;
        font-size: 2.4rem;
        letter-spacing: 0;
        line-height: 1.15;
        margin-bottom: 0.5rem;
        overflow-wrap: anywhere;
        text-wrap: balance;
      }

      time {
        font-size: 0.78rem;
        color: var(--faint);
        letter-spacing: 0;
      }

      .prose :global(h2) {
        font-family: "Instrument Serif", serif;
        font-weight: 400;
        font-size: 1.5rem;
        margin-top: 2.5rem;
        margin-bottom: 0.8rem;
      }

      .prose :global(h3) {
        font-family: "DM Sans", sans-serif;
        font-weight: 500;
        font-size: 1rem;
        margin-top: 2rem;
        margin-bottom: 0.6rem;
      }

      .prose :global(p) {
        margin-bottom: 1.2rem;
        color: var(--ink);
      }

      .prose {
        overflow-wrap: break-word;
      }

      .prose::after {
        clear: both;
        content: "";
        display: block;
      }

      .prose :global(a) {
        color: var(--ink);
        text-decoration: none;
        border-bottom: 1.5px solid var(--rule);
        transition: border-color 0.2s;
        overflow-wrap: anywhere;
      }

      .prose :global(a:hover) {
        border-bottom-color: var(--ink);
      }

      .prose :global(sup) {
        line-height: 0;
      }

      .prose :global(a[data-footnote-ref]) {
        align-items: center;
        border: 1px solid var(--rule);
        border-radius: 999px;
        display: inline-flex;
        font-size: 0.6em;
        font-variant-numeric: tabular-nums;
        font-weight: 500;
        justify-content: center;
        letter-spacing: 0;
        line-height: 1.35;
        margin: 0 0.14em;
        min-width: 1.55em;
        padding: 0.02em 0.5em;
        transform: translateY(-0.08em);
        vertical-align: super;
      }

      .prose :global(ul),
      .prose :global(ol) {
        margin-bottom: 1.2rem;
        padding-left: 1.2rem;
      }

      .prose :global(li) {
        margin-bottom: 0.4rem;
      }

      .prose :global(blockquote) {
        border-left: 3px solid var(--amber);
        padding-left: 1rem;
        margin: 1.5rem 0;
        color: var(--mid);
        font-style: italic;
      }

      .prose :global(code) {
        font-size: 0.88em;
        background: #e8e3db;
        padding: 0.15em 0.4em;
        border-radius: 3px;
        overflow-wrap: anywhere;
      }

      .prose :global(pre) {
        background: var(--ink);
        color: var(--cream);
        padding: 1.2rem;
        border-radius: 6px;
        overflow-x: auto;
        margin-bottom: 1.5rem;
        font-size: 0.85rem;
        line-height: 1.5;
      }

      .prose :global(pre code) {
        background: none;
        padding: 0;
        border-radius: 0;
      }

      .prose :global(hr) {
        border: none;
        border-top: 1px solid var(--rule);
        margin: 2rem 0;
      }

      .prose :global(.article-figure) {
        border-bottom: 1px solid var(--rule);
        border-top: 1px solid var(--rule);
        margin: 2.2rem 0;
        padding: 1rem 0;
      }

      .prose :global(.article-figure figcaption) {
        color: var(--mid);
        font-size: 0.74rem;
        font-weight: 500;
        letter-spacing: 0;
        margin-bottom: 0.85rem;
        text-transform: uppercase;
      }

      .prose :global(.sketch-figure) {
        margin-left: 50%;
        transform: translateX(-50%);
        width: min(760px, calc(100vw - 1rem));
      }

      .prose :global(.sketch-figure img) {
        aspect-ratio: auto 1200 / 800;
        border: 1px solid var(--rule);
        border-radius: 4px;
        display: block;
        height: auto;
        margin: 0;
        object-fit: contain;
        width: 100%;
      }

      .prose :global(.gate-stage) {
        background:
          radial-gradient(circle at 48% 52%, rgba(63, 143, 138, 0.1), transparent 33%),
          radial-gradient(circle at 88% 74%, rgba(191, 95, 90, 0.11), transparent 30%),
          linear-gradient(135deg, #f6efe4, #e7ddcf);
        border: 1px solid var(--rule);
        cursor: crosshair;
        outline: none;
        overflow: hidden;
        position: relative;
        touch-action: manipulation;
      }

      .prose :global(.gate-stage:focus-visible) {
        box-shadow: 0 0 0 3px rgba(63, 143, 138, 0.24);
      }

      .prose :global(.gate-map) {
        display: block;
        min-height: 18rem;
        width: 100%;
      }

      .prose :global(.gate-map text),
      .prose :global(.consequence-map text) {
        fill: var(--mid);
        font-family: "DM Sans", sans-serif;
        font-size: 14px;
        font-weight: 500;
        text-transform: uppercase;
      }

      .prose :global(.gate-panel) {
        fill: rgba(247, 241, 232, 0.5);
        stroke: rgba(217, 208, 195, 0.72);
        stroke-width: 1;
      }

      .prose :global(.gate-grid) {
        fill: none;
        opacity: 0.35;
        stroke: rgba(26, 23, 20, 0.08);
        stroke-dasharray: 5 8;
        stroke-linecap: round;
        stroke-width: 1.4;
      }

      .prose :global(.gate-meter text) {
        font-size: 12px;
        letter-spacing: 0;
      }

      .prose :global(.gate-meter .meter-rail) {
        fill: rgba(26, 23, 20, 0.12);
      }

      .prose :global([data-coverage-fill]),
      .prose :global([data-blast-fill]) {
        transition: width 0.18s ease;
      }

      .prose :global([data-coverage-fill]) {
        fill: var(--teal);
      }

      .prose :global([data-blast-fill]) {
        fill: var(--amber);
      }

      .prose :global(.gate-stage[data-route="stop"] [data-blast-fill]) {
        fill: var(--rose);
      }

      .prose :global(.gate-track),
      .prose :global(.gate-route),
      .prose :global(.aperture-sheen),
      .prose :global(.endpoint-stem),
      .prose :global(.containment-ring),
      .prose :global(.hold-barrier),
      .prose :global(.hold-cap) {
        fill: none;
        stroke-linecap: round;
        stroke-linejoin: round;
      }

      .prose :global(.gate-track) {
        opacity: 0.3;
        stroke: rgba(26, 23, 20, 0.16);
        stroke-width: 9;
        transition:
          opacity 0.18s ease,
          stroke 0.18s ease;
      }

      .prose :global(.gate-stage[data-route="predict"] .track-predict) {
        opacity: 0.58;
        stroke: rgba(63, 143, 138, 0.34);
      }

      .prose :global(.gate-stage[data-route="contain"] .track-contain) {
        opacity: 0.62;
        stroke: rgba(201, 123, 58, 0.36);
      }

      .prose :global(.gate-stage[data-route="stop"] .track-stop) {
        opacity: 0.66;
        stroke: rgba(191, 95, 90, 0.38);
      }

      .prose :global(.gate-route) {
        opacity: 0.95;
        stroke: url(#gate-safe-route);
        stroke-width: 6;
        transition: stroke 0.18s ease;
      }

      .prose :global(.gate-stage[data-route="contain"] .gate-route) {
        stroke: url(#gate-canary-route);
      }

      .prose :global(.gate-stage[data-route="stop"] .gate-route) {
        stroke: url(#gate-hold-route);
      }

      .prose :global(.aperture-shadow) {
        fill: rgba(26, 23, 20, 0.06);
      }

      .prose :global(.aperture-blast) {
        fill: rgba(191, 95, 90, 0.12);
        stroke: rgba(191, 95, 90, 0.18);
        stroke-width: 1.2;
        transition:
          opacity 0.18s ease,
          r 0.18s ease;
      }

      .prose :global(.aperture-outer) {
        fill: rgba(239, 230, 217, 0.92);
        stroke: rgba(26, 23, 20, 0.18);
        stroke-width: 1.4;
      }

      .prose :global(.aperture-glass) {
        fill: url(#gate-glass);
        stroke: rgba(26, 23, 20, 0.2);
        stroke-width: 2;
      }

      .prose :global(.aperture-opening) {
        fill: rgba(247, 241, 232, 0.98);
        stroke: rgba(26, 23, 20, 0.22);
        stroke-width: 1.6;
        transition:
          width 0.18s ease,
          x 0.18s ease;
      }

      .prose :global(.aperture-sheen) {
        opacity: 0.42;
        stroke: rgba(255, 250, 241, 0.92);
        stroke-width: 2;
      }

      .prose :global(.route-end) {
        color: rgba(102, 92, 82, 0.72);
        opacity: 0.58;
        transition:
          opacity 0.18s ease,
          transform 0.18s ease;
      }

      .prose :global(.gate-stage[data-route="predict"] .route-predict),
      .prose :global(.gate-stage[data-route="contain"] .route-contain),
      .prose :global(.gate-stage[data-route="stop"] .route-stop) {
        opacity: 1;
        transform: translateX(3px);
      }

      .prose :global(.route-end text) {
        fill: currentColor;
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0;
      }

      .prose :global(.containment-ring) {
        fill: rgba(247, 241, 232, 0.18);
        stroke: currentColor;
        stroke-width: 2;
      }

      .prose :global(.containment-ring) {
        stroke-dasharray: 4 4;
      }

      .prose :global(.endpoint-stem) {
        opacity: 0.76;
        stroke: currentColor;
        stroke-width: 2.4;
      }

      .prose :global(.route-icon-line),
      .prose :global(.route-icon-mark) {
        fill: none;
        stroke: currentColor;
        stroke-linecap: round;
        stroke-linejoin: round;
        stroke-width: 2.4;
      }

      .prose :global(.route-predict) {
        color: var(--teal);
      }

      .prose :global(.route-contain) {
        color: var(--amber);
      }

      .prose :global(.route-stop) {
        color: var(--rose);
      }

      .prose :global(.canary-dot) {
        fill: currentColor;
      }

      .prose :global(.hold-barrier) {
        stroke: currentColor;
        stroke-width: 5.5;
      }

      .prose :global(.hold-cap) {
        opacity: 0.58;
        stroke: currentColor;
        stroke-width: 2;
      }

      .prose :global(.blast-halo) {
        fill: rgba(191, 95, 90, 0.12);
        pointer-events: none;
        stroke: rgba(191, 95, 90, 0.24);
        stroke-width: 1.5;
        transition:
          opacity 0.18s ease,
          r 0.18s ease;
      }

      .prose :global(.gate-pulse) {
        fill: var(--amber);
        pointer-events: none;
        transition:
          fill 0.18s ease,
          r 0.18s ease;
      }

      .prose :global(.gate-stage[data-route="predict"] .gate-pulse) {
        fill: var(--teal);
      }

      .prose :global(.gate-stage[data-route="stop"] .gate-pulse) {
        fill: var(--rose);
      }

      .prose :global(.gate-pulse-ring) {
        fill: none;
        pointer-events: none;
        stroke: rgba(201, 123, 58, 0.48);
        stroke-width: 2;
        transform-origin: center;
      }

      .prose :global(.gate-stage[data-route="predict"] .gate-pulse-ring) {
        stroke: rgba(63, 143, 138, 0.5);
      }

      .prose :global(.gate-stage[data-route="stop"] .gate-pulse-ring) {
        stroke: rgba(191, 95, 90, 0.6);
      }

      .prose :global(.gate-status) {
        align-items: center;
        background: rgba(245, 240, 232, 0.82);
        border-top: 1px solid var(--rule);
        color: var(--mid);
        display: flex;
        font-size: 0.78rem;
        line-height: 1.35;
        margin: 0;
        min-height: 3.8rem;
        padding: 0.65rem 0.8rem;
      }

      .prose :global(.consequence-stage) {
        background: linear-gradient(135deg, #f4ede3, #e8dfd2);
        border: 1px solid var(--rule);
        cursor: ns-resize;
        outline: none;
        overflow: hidden;
        position: relative;
        touch-action: manipulation;
      }

      .prose :global(.consequence-stage:focus-visible) {
        box-shadow: 0 0 0 3px rgba(201, 123, 58, 0.24);
      }

      .prose :global(.consequence-map) {
        display: block;
        min-height: 17rem;
        width: 100%;
      }

      .prose :global(.consequence-panel) {
        fill: rgba(247, 241, 232, 0.7);
        stroke: rgba(217, 208, 195, 0.8);
        stroke-width: 1;
      }

      .prose :global(.consequence-track) {
        fill: none;
        stroke: rgba(26, 23, 20, 0.18);
        stroke-linecap: round;
        stroke-width: 9;
      }

      .prose :global(.consequence-lane) {
        opacity: 0.64;
        transition:
          opacity 0.18s ease,
          transform 0.18s ease;
      }

      .prose :global(.consequence-stage[data-level="local"] .lane-local),
      .prose :global(.consequence-stage[data-level="reversible"] .lane-reversible),
      .prose :global(.consequence-stage[data-level="disruptive"] .lane-disruptive),
      .prose :global(.consequence-stage[data-level="irreversible"] .lane-irreversible) {
        opacity: 1;
        transform: translateY(-3px);
      }

      .prose :global(.consequence-control) {
        fill: rgba(247, 241, 232, 0.9);
        stroke-width: 3;
      }

      .prose :global(.control-local) {
        stroke: rgba(63, 143, 138, 0.74);
      }

      .prose :global(.control-reversible) {
        stroke: rgba(201, 123, 58, 0.58);
      }

      .prose :global(.control-disruptive) {
        stroke: rgba(191, 95, 90, 0.58);
      }

      .prose :global(.control-irreversible) {
        fill: rgba(191, 95, 90, 0.12);
        stroke: rgba(191, 95, 90, 0.76);
        stroke-width: 4;
      }

      .prose :global(.control-symbol),
      .prose :global(.control-lock) {
        fill: none;
        stroke: currentColor;
        stroke-linecap: round;
        stroke-linejoin: round;
        stroke-width: 5;
      }

      .prose :global(.lane-local) {
        color: var(--teal);
      }

      .prose :global(.lane-reversible) {
        color: var(--amber);
      }

      .prose :global(.lane-disruptive),
      .prose :global(.lane-irreversible) {
        color: var(--rose);
      }

      .prose :global(.control-lock) {
        stroke-width: 4;
      }

      .prose :global(.control-note) {
        fill: rgba(102, 92, 82, 0.72);
        font-size: 12px;
      }

      .prose :global(.warning-light) {
        fill: var(--amber);
      }

      .prose :global(.consequence-trail) {
        fill: none;
        stroke: var(--teal);
        stroke-linecap: round;
        stroke-width: 5;
      }

      .prose :global(.consequence-stage[data-level="reversible"] .consequence-trail) {
        stroke: var(--amber);
      }

      .prose :global(.consequence-stage[data-level="disruptive"] .consequence-trail),
      .prose :global(.consequence-stage[data-level="irreversible"] .consequence-trail) {
        stroke: var(--rose);
      }

      .prose :global(.consequence-token) {
        fill: var(--teal);
        transition: fill 0.18s ease;
      }

      .prose :global(.consequence-token-ring) {
        fill: none;
        stroke: rgba(63, 143, 138, 0.5);
        stroke-width: 2;
      }

      .prose :global(.consequence-stage[data-level="reversible"] .consequence-token) {
        fill: var(--amber);
      }

      .prose :global(.consequence-stage[data-level="reversible"] .consequence-token-ring) {
        stroke: rgba(201, 123, 58, 0.55);
      }

      .prose :global(.consequence-stage[data-level="disruptive"] .consequence-token),
      .prose :global(.consequence-stage[data-level="irreversible"] .consequence-token) {
        fill: var(--rose);
      }

      .prose :global(.consequence-stage[data-level="disruptive"] .consequence-token-ring),
      .prose :global(.consequence-stage[data-level="irreversible"] .consequence-token-ring) {
        stroke: rgba(191, 95, 90, 0.65);
      }

      .prose :global(.consequence-stop) {
        fill: rgba(26, 23, 20, 0.24);
        transition: fill 0.18s ease;
      }

      .prose :global(.consequence-stage[data-level="local"] .stop-local) {
        fill: var(--teal);
      }

      .prose :global(.consequence-stage[data-level="reversible"] .stop-reversible) {
        fill: var(--amber);
      }

      .prose :global(.consequence-stage[data-level="disruptive"] .stop-disruptive),
      .prose :global(.consequence-stage[data-level="irreversible"] .stop-irreversible) {
        fill: var(--rose);
      }

      .prose :global(.consequence-status) {
        align-items: center;
        background: rgba(245, 240, 232, 0.82);
        border-top: 1px solid var(--rule);
        color: var(--mid);
        display: flex;
        font-size: 0.78rem;
        line-height: 1.35;
        margin: 0;
        min-height: 3.8rem;
        padding: 0.65rem 0.8rem;
      }

      .prose :global(.sand-stage) {
        background:
          radial-gradient(circle at 42% 50%, rgba(63, 143, 138, 0.1), transparent 34%),
          radial-gradient(circle at 86% 52%, rgba(191, 95, 90, 0.12), transparent 31%),
          linear-gradient(135deg, #f3ebdf, #e8dfd2);
        border: 1px solid var(--rule);
        cursor: pointer;
        min-height: 20rem;
        overflow: hidden;
        position: relative;
        touch-action: manipulation;
      }

      .prose :global(.sand-stage:focus-visible) {
        box-shadow: 0 0 0 3px rgba(191, 95, 90, 0.24);
      }

      .prose :global(.evidence-map) {
        display: block;
        min-height: 17rem;
        width: 100%;
      }

      .prose :global(.evidence-map text) {
        fill: var(--mid);
        font-family: "DM Sans", sans-serif;
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 0;
        text-transform: uppercase;
      }

      .prose :global(.evidence-panel) {
        fill: rgba(247, 241, 232, 0.55);
        stroke: rgba(217, 208, 195, 0.74);
        stroke-width: 1;
      }

      .prose :global(.evidence-shadow-route),
      .prose :global(.evidence-route),
      .prose :global(.claim-line),
      .prose :global(.filter-slot),
      .prose :global(.filter-crack),
      .prose :global(.execution-boundary),
      .prose :global(.execution-lines),
      .prose :global(.quarantine-basin),
      .prose :global(.quarantine-mark) {
        fill: none;
        stroke-linecap: round;
        stroke-linejoin: round;
      }

      .prose :global(.evidence-shadow-route) {
        opacity: 0.34;
        stroke: rgba(26, 23, 20, 0.14);
        stroke-width: 8;
      }

      .prose :global(.evidence-route) {
        opacity: 0.12;
        stroke-width: 6;
        transition:
          opacity 0.18s ease,
          stroke-width 0.18s ease;
      }

      .prose :global(.route-self),
      .prose :global(.route-reject) {
        stroke: url(#evidence-bad-flow);
      }

      .prose :global(.route-pass) {
        stroke: url(#evidence-safe-flow);
      }

      .prose :global(.sand-stage[data-mode="self"] .route-self),
      .prose :global(.sand-stage[data-mode="independent"] .route-pass),
      .prose :global(.sand-stage[data-mode="independent"] .route-reject) {
        opacity: 0.96;
      }

      .prose :global(.claim-sheet) {
        fill: rgba(247, 241, 232, 0.82);
        stroke: rgba(26, 23, 20, 0.2);
        stroke-width: 1.6;
      }

      .prose :global(.claim-line) {
        stroke: rgba(26, 23, 20, 0.23);
        stroke-width: 2;
      }

      .prose :global(.claim-badge) {
        fill: rgba(191, 95, 90, 0.18);
        stroke: rgba(191, 95, 90, 0.62);
        stroke-width: 2;
      }

      .prose :global(.filter-shadow) {
        fill: rgba(26, 23, 20, 0.06);
      }

      .prose :global(.filter-glass) {
        fill: rgba(247, 241, 232, 0.82);
        stroke: rgba(26, 23, 20, 0.32);
        stroke-width: 2.2;
      }

      .prose :global(.filter-slot) {
        stroke: rgba(63, 143, 138, 0.68);
        stroke-width: 4.6;
        transition: stroke 0.18s ease;
      }

      .prose :global(.filter-crack) {
