            if (mode === "self") {
              for (let i = 0; i < 28; i += 1) {
                particles.push({
                  bad: true,
                  caught: false,
                  lane: -2 + Math.floor(Math.random() * 5),
                  settled: true,
                  stopX: 408 + Math.random() * 74,
                  stopY: 250 + Math.random() * 20,
                  x: 408 + Math.random() * 74,
                  y: 250 + Math.random() * 20,
                  vx: -0.08 + Math.random() * 0.16,
                  vy: -0.05 + Math.random() * 0.1,
                  r: 1.9 + Math.random() * 1.8,
                  life: 40 + Math.random() * 80,
                  color: `rgba(${182 + Math.random() * 36}, ${48 + Math.random() * 26}, ${42 + Math.random() * 22}, 0.9)`,
                });
              }
            } else {
              for (let i = 0; i < 26; i += 1) {
                particles.push({
                  bad: true,
                  caught: true,
                  lane: -2 + Math.floor(Math.random() * 5),
                  settled: false,
                  stopX: 200 + Math.random() * 62,
                  stopY: 236 + Math.random() * 34,
                  x: 200 + Math.random() * 62,
                  y: 236 + Math.random() * 34,
                  vx: -0.12 + Math.random() * 0.24,
                  vy: -0.08 + Math.random() * 0.16,
                  r: 1.8 + Math.random() * 1.7,
                  life: 30 + Math.random() * 70,
                  color: `rgba(${176 + Math.random() * 36}, ${54 + Math.random() * 28}, ${46 + Math.random() * 22}, 0.82)`,
                });
              }
            }
          }

          function setMode(next) {
            mode = next;
            stage.dataset.mode = mode;
            if (modeLabel) {
              modeLabel.textContent =
                mode === "self"
                  ? "self-graded: unsupported claims hit production"
                  : "independent evidence: bad grains are trapped before execution";
            }
            seedParticles();
            caught = mode === "independent" ? 26 : 0;
            impact = mode === "self" ? 36 : 0;
            last = performance.now();
          }

          function shouldAnimate() {
            return !reduceMotion && isIntersecting && !document.hidden;
          }

          function stopFrame() {
            if (animationId) cancelAnimationFrame(animationId);
            animationId = 0;
          }

          function scheduleFrame() {
            if (animationId || !shouldAnimate()) return;
            last = performance.now();
            animationId = requestAnimationFrame(draw);
          }

          function updateFrameState() {
            if (shouldAnimate()) {
              scheduleFrame();
            } else {
              stopFrame();
              draw(performance.now(), false);
            }
          }

          function streamY(particle, x) {
            const lane = particle.lane * 6;
            if (x < 180) return 116 + lane + (x - 92) * 0.16;
            if (x < 278) return 130 + lane + (x - 180) * 0.22;
            if (mode === "independent" && particle.bad) return 244 + lane * 0.24;
            if (x < 388) return 154 + lane + (x - 278) * 0.24;
            return 248 + lane * 0.35;
          }

          function spawn() {
            const limit = mode === "self" ? 180 : 156;
            const count = mode === "self" ? 4 : 3;
            for (let i = 0; i < count && particles.length < limit; i += 1) {
              particles.push(makeParticle(performance.now() + i));
            }
          }

          function collideGate(particle, previousX) {
            if (mode === "self") {
              const sieveX = 278;
              const insideTornSieve =
                previousX < sieveX &&
                particle.x >= sieveX &&
                particle.y > 88 &&
                particle.y < 270;
              if (insideTornSieve) {
                particle.vx += particle.bad ? 0.62 : 0.28;
                particle.vy *= 0.42;
              }
              if (particle.bad && particle.x > 372 && particle.y > 138) {
                particle.color = "rgba(183, 54, 46, 0.9)";
              }
              return;
            }

            const sieveX = 278;
            const crossedSieve =
              previousX < sieveX &&
              particle.x >= sieveX &&
              particle.y > 82 &&
              particle.y < 274;
            if (crossedSieve && particle.bad) {
              particle.caught = true;
              particle.stopX = 196 + Math.random() * 70;
              particle.stopY = 238 + Math.random() * 32;
              particle.x = sieveX - particle.r - 0.4;
              particle.vx = -Math.abs(particle.vx) * 0.48;
              particle.vy *= 0.58;
              caught += 0.9;
              particle.color = "rgba(189, 64, 54, 0.86)";
            }
            if (crossedSieve && !particle.bad) {
              particle.vx += 0.42;
            }
          }

          function step() {
            spawn();
            caught *= 0.994;
            for (const particle of particles) {
              const previousX = particle.x;
              particle.life += 1;
              if (particle.caught || particle.settled) {
                particle.vx += (particle.stopX - particle.x) * 0.012;
                particle.vy += (particle.stopY - particle.y) * 0.026;
                particle.vx *= 0.86;
                particle.vy *= 0.86;
              } else {
                particle.vx += mode === "self" ? 0.01 : 0.004;
                particle.vy += (streamY(particle, particle.x) - particle.y) * 0.075;
                particle.vx = clamp(particle.vx, 0.52, mode === "self" ? 3.4 : 2.7);
                particle.vy = clamp(particle.vy, -1.45, 1.45);
              }
              particle.x += particle.vx;
              particle.y += particle.vy;
              collideGate(particle, previousX);

              if (mode === "self" && particle.bad && !particle.settled && particle.x > 398) {
                particle.settled = true;
                particle.stopX = 408 + Math.random() * 76;
                particle.stopY = 250 + Math.random() * 20;
                particle.vx *= 0.35;
                impact += 0.25;
              }

              if (particle.x < particle.r) {
                particle.x = particle.r;
                particle.vx = Math.abs(particle.vx) * 0.5;
              }
              if (particle.x > world.width - particle.r) {
                particle.x = world.width - particle.r;
                particle.vx = -Math.abs(particle.vx) * 0.45;
              }
              if (particle.y > world.height - 24 - particle.r) {
                particle.y = world.height - 24 - particle.r;
                particle.vy = -Math.abs(particle.vy) * 0.22;
                particle.vx *= 0.86;
              }
            }

            const badInExecution = particles.filter(
              (particle) =>
                particle.bad &&
                particle.x > 380 &&
                particle.x < 510 &&
                particle.y > 142 &&
                particle.y < 292,
            ).length;
            impact = impact * 0.92 + badInExecution * 0.08;

            particles = particles.filter((particle) => {
              const settledTooLong =
                particle.life > 260 && (particle.caught || particle.settled);
              const exited = particle.life > 150 && particle.x > world.width + 36;
              return particle.y < world.height + 42 && !settledTooLong && !exited;
            });
          }

          function drawHopper() {
            ctx.save();
            ctx.translate(46, 66);
            ctx.rotate(-0.08);
            ctx.fillStyle = "rgba(245, 240, 232, 0.88)";
            ctx.strokeStyle = "rgba(26, 23, 20, 0.28)";
            ctx.lineWidth = 2.4;
            ctx.beginPath();
            roundedRect(0, 0, 108, 74, 6);
            ctx.fill();
            ctx.stroke();
            ctx.fillStyle = "rgba(26, 23, 20, 0.14)";
            ctx.beginPath();
            roundedRect(34, -8, 38, 15, 5);
            ctx.fill();
            ctx.strokeStyle = "rgba(26, 23, 20, 0.18)";
            ctx.lineWidth = 2;
            for (let y = 22; y < 60; y += 13) {
              ctx.beginPath();
              ctx.moveTo(18, y);
              ctx.lineTo(88, y);
              ctx.stroke();
            }
            ctx.strokeStyle = "rgba(26, 23, 20, 0.24)";
            ctx.beginPath();
            ctx.moveTo(86, 60);
            ctx.lineTo(132, 92);
            ctx.stroke();
            ctx.restore();
          }

          function drawStreamGuide() {
            ctx.save();
            ctx.lineCap = "round";
            ctx.lineJoin = "round";
            ctx.strokeStyle = "rgba(26, 23, 20, 0.11)";
            ctx.lineWidth = 7;
            ctx.beginPath();
            ctx.moveTo(118, 128);
            ctx.bezierCurveTo(178, 144, 226, 156, 278, 174);
            ctx.bezierCurveTo(338, 196, 386, 226, 444, 254);
            ctx.stroke();
            ctx.strokeStyle =
              mode === "self" ? "rgba(191, 95, 90, 0.2)" : "rgba(63, 143, 138, 0.18)";
            ctx.lineWidth = 2;
            ctx.setLineDash([10, 12]);
            ctx.beginPath();
            ctx.moveTo(118, 128);
            ctx.bezierCurveTo(178, 144, 226, 156, 278, 174);
            ctx.bezierCurveTo(338, 196, 386, 226, 444, 254);
            ctx.stroke();
            ctx.setLineDash([]);
            ctx.restore();
          }

          function drawBasin() {
            const spill = clamp(impact / 58, 0, 1);
            ctx.save();
            ctx.fillStyle = "rgba(245, 240, 232, 0.86)";
            ctx.strokeStyle = "rgba(26, 23, 20, 0.28)";
            ctx.lineWidth = 2.5;
            ctx.beginPath();
            roundedRect(382, 108, 112, 174, 10);
            ctx.fill();
            ctx.stroke();
            ctx.fillStyle = "rgba(26, 23, 20, 0.08)";
            for (let y = 128; y < 238; y += 26) {
              ctx.beginPath();
              roundedRect(396, y, 84, 16, 4);
              ctx.fill();
            }
            ctx.fillStyle = mode === "self" ? "rgba(191, 95, 90, 0.9)" : "rgba(63, 143, 138, 0.8)";
            ctx.beginPath();
            ctx.arc(470, 118, 4, 0, Math.PI * 2);
            ctx.fill();
            ctx.strokeStyle = "rgba(26, 23, 20, 0.32)";
            ctx.lineWidth = 2;
            ctx.beginPath();
            ctx.arc(438, 258, 22, Math.PI, Math.PI * 2);
            ctx.stroke();
            ctx.strokeStyle = mode === "self" ? "rgba(191, 95, 90, 0.72)" : "rgba(63, 143, 138, 0.72)";
            ctx.beginPath();
            ctx.moveTo(418, 258);
            ctx.lineTo(mode === "self" ? 456 : 432, mode === "self" ? 230 - spill * 18 : 246);
            ctx.stroke();
            if (spill > 0.04) {
              const alpha = clamp(0.1 + spill * 0.42, 0.1, 0.52);
              ctx.fillStyle = `rgba(191, 95, 90, ${alpha})`;
              ctx.beginPath();
              roundedRect(384, 196 - spill * 18, 108, 78 + spill * 24, 12);
              ctx.fill();
              ctx.strokeStyle = `rgba(191, 95, 90, ${alpha + 0.14})`;
              ctx.lineWidth = 3;
              ctx.beginPath();
              ctx.moveTo(404, 274);
              ctx.bezierCurveTo(426, 294, 466, 292, 486, 270);
              ctx.stroke();
            }
            ctx.restore();
          }

          function drawGate() {
            ctx.save();
            ctx.lineCap = "round";
            ctx.lineWidth = 4;
            ctx.fillStyle = "rgba(245, 240, 232, 0.74)";
            ctx.strokeStyle = "rgba(26, 23, 20, 0.28)";
            ctx.beginPath();
            roundedRect(238, 76, 82, 208, 9);
            ctx.fill();
            ctx.stroke();
            if (mode === "self") {
              ctx.strokeStyle = "rgba(191, 95, 90, 0.68)";
              ctx.lineWidth = 4;
              for (let y = 96; y < 262; y += 30) {
                ctx.beginPath();
                ctx.moveTo(250, y);
                ctx.lineTo(306, y + 18);
                ctx.stroke();
              }
              ctx.strokeStyle = "rgba(191, 95, 90, 0.88)";
              ctx.setLineDash([12, 9]);
              ctx.beginPath();
              ctx.moveTo(270, 88);
              ctx.lineTo(292, 134);
              ctx.lineTo(266, 170);
              ctx.lineTo(300, 224);
              ctx.lineTo(278, 270);
              ctx.stroke();
              ctx.setLineDash([]);
              ctx.fillStyle = "rgba(191, 95, 90, 0.1)";
              ctx.beginPath();
              roundedRect(282, 104, 28, 154, 8);
              ctx.fill();
            } else {
              ctx.strokeStyle = "rgba(63, 143, 138, 0.82)";
              ctx.lineWidth = 3;
              for (let y = 92; y < 270; y += 18) {
                ctx.beginPath();
                ctx.moveTo(250, y);
                ctx.lineTo(308, y + 12);
                ctx.stroke();
              }
              for (let x = 252; x < 308; x += 14) {
                ctx.beginPath();
                ctx.moveTo(x, 88);
                ctx.lineTo(x + 18, 268);
                ctx.stroke();
              }
              ctx.fillStyle = "rgba(63, 143, 138, 0.14)";
              ctx.beginPath();
              roundedRect(186, 244, 92 + clamp(caught, 0, 46), 30, 8);
              ctx.fill();
              ctx.strokeStyle = "rgba(191, 95, 90, 0.48)";
              ctx.lineWidth = 2;
              ctx.beginPath();
              ctx.moveTo(190, 244);
              ctx.lineTo(274, 244);
              ctx.stroke();
            }
            ctx.restore();
          }

          function draw(now, forceStatic = false) {
            animationId = 0;
            const animate = !forceStatic && shouldAnimate();
            const delta = Math.min(64, now - last);
            last = now;
            if (animate) {
              const steps = Math.max(1, Math.round(delta / 16));
              for (let i = 0; i < steps; i += 1) step();
            }

            ctx.clearRect(0, 0, world.width, world.height);
            const shake =
              animate && mode === "self" && impact > 24
                ? Math.sin(now / 34) * clamp(impact / 34, 0, 2.6)
                : 0;
            ctx.save();
            ctx.translate(shake, 0);
            ctx.fillStyle = "#eee8de";
            ctx.fillRect(0, 0, world.width, world.height);

            drawHopper();
            drawStreamGuide();
            drawBasin();
            drawGate();

            for (const particle of particles) {
              ctx.strokeStyle = particle.color;
              ctx.lineCap = "round";
              ctx.lineWidth = Math.max(1.8, particle.r * 1.15);
              ctx.beginPath();
              ctx.moveTo(particle.x - particle.vx * 1.4, particle.y - particle.vy * 0.8);
              ctx.lineTo(particle.x + particle.vx * 0.35, particle.y + particle.vy * 0.25);
              ctx.stroke();
            }

            ctx.restore();
            if (animate) scheduleFrame();
          }

          stage.addEventListener("click", () => {
            stopFrame();
            setMode(mode === "self" ? "independent" : "self");
            draw(performance.now(), true);
            updateFrameState();
          });
          stage.addEventListener("keydown", (event) => {
            if (event.key !== "Enter" && event.key !== " ") return;
            event.preventDefault();
            stopFrame();
            setMode(mode === "self" ? "independent" : "self");
            draw(performance.now(), true);
            updateFrameState();
          });

          resize();
          setMode("self");
          draw(performance.now(), true);
          window.addEventListener("resize", () => {
            stopFrame();
            resize();
            draw(performance.now(), true);
            updateFrameState();
          });

          if ("IntersectionObserver" in window) {
            const observer = new IntersectionObserver(([entry]) => {
              isIntersecting = Boolean(entry?.isIntersecting);
              updateFrameState();
            });
            observer.observe(stage);
          }

          document.addEventListener("visibilitychange", updateFrameState);
          updateFrameState();
        }

        function initSandboxStage(stage) {
          const canvas = stage.querySelector("canvas");
          const ctx = canvas?.getContext("2d");
          const modeLabel = stage.querySelector(".sandbox-mode");
          if (!canvas || !ctx) return;

          const world = { width: 540, height: 360 };
          const box = { x: 88, y: 70, width: 330, height: 214 };
          const agent = {
            x: 226,
            y: box.y + box.height - 38,
            vx: 1.55,
            width: 34,
            height: 30,
            phase: 0,
          };
          let bump = 0;
          let last = performance.now();
          let animationId = 0;
          let isIntersecting = !("IntersectionObserver" in window);

          function resize() {
            const rect = stage.getBoundingClientRect();
            const width = Math.max(320, rect.width);
            const height = width * (world.height / world.width);
            const scale = window.devicePixelRatio || 1;
            canvas.style.height = `${height}px`;
            canvas.width = Math.round(width * scale);
            canvas.height = Math.round(height * scale);
            ctx.setTransform(
              canvas.width / world.width,
              0,
              0,
              canvas.height / world.height,
              0,
              0,
            );
          }

          function roundedRect(x, y, width, height, radius) {
            const r = Math.min(radius, width / 2, height / 2);
            ctx.moveTo(x + r, y);
            ctx.lineTo(x + width - r, y);
            ctx.quadraticCurveTo(x + width, y, x + width, y + r);
            ctx.lineTo(x + width, y + height - r);
            ctx.quadraticCurveTo(x + width, y + height, x + width - r, y + height);
            ctx.lineTo(x + r, y + height);
            ctx.quadraticCurveTo(x, y + height, x, y + height - r);
            ctx.lineTo(x, y + r);
            ctx.quadraticCurveTo(x, y, x + r, y);
          }

          function nudgeAgent(strength = 1) {
            const direction = Math.random() > 0.5 ? 1 : -1;
            agent.vx = direction * (1.8 + Math.random() * 0.75) * strength;
            bump = Math.max(bump, 12 * strength);
            if (modeLabel) {
              modeLabel.textContent = "contained exploration: the boundary absorbs the bump";
            }
          }

          function shouldAnimate() {
            return !reduceMotion && isIntersecting && !document.hidden;
          }

          function stopFrame() {
            if (animationId) cancelAnimationFrame(animationId);
            animationId = 0;
          }

          function scheduleFrame() {
            if (animationId || !shouldAnimate()) return;
            last = performance.now();
            animationId = requestAnimationFrame(draw);
          }

          function updateFrameState() {
            if (shouldAnimate()) {
              scheduleFrame();
            } else {
              stopFrame();
              draw(performance.now(), true);
            }
          }

          function step() {
            const floor = box.y + box.height - 34;
            agent.phase += Math.abs(agent.vx) * 0.1;
            agent.x += agent.vx;
            agent.vx += Math.sin(performance.now() / 760) * 0.018;
            agent.vx = clamp(agent.vx, -2.45, 2.45);
            agent.y = floor + Math.sin(agent.phase * 2) * 1.4;

            const minX = box.x + agent.width / 2 + 12;
            const maxX = box.x + box.width - agent.width / 2 - 12;
            if (agent.x < minX || agent.x > maxX) {
              agent.x = clamp(agent.x, minX, maxX);
              agent.vx *= -0.94;
              bump = 14;
            }
            bump *= 0.9;
          }

          function drawProductionPanel() {
            ctx.save();
            ctx.fillStyle = "rgba(245, 240, 232, 0.64)";
            ctx.strokeStyle = "rgba(26, 23, 20, 0.18)";
            ctx.lineWidth = 2;
            ctx.beginPath();
            roundedRect(446, 112, 54, 120, 8);
            ctx.fill();
            ctx.stroke();
            ctx.strokeStyle = "rgba(26, 23, 20, 0.22)";
            for (let y = 134; y < 210; y += 22) {
              ctx.beginPath();
              ctx.moveTo(458, y);
              ctx.lineTo(488, y);
              ctx.stroke();
            }
            ctx.fillStyle = "rgba(63, 143, 138, 0.56)";
            ctx.beginPath();
            ctx.arc(488, 122, 4, 0, Math.PI * 2);
            ctx.fill();
            ctx.restore();
          }

          function drawGlassBox(shake) {
            ctx.save();
            ctx.translate(shake, 0);
            ctx.fillStyle = "rgba(170, 209, 210, 0.16)";
            ctx.strokeStyle = "rgba(63, 143, 138, 0.62)";
            ctx.lineWidth = 4;
            ctx.beginPath();
            roundedRect(box.x, box.y, box.width, box.height, 12);
            ctx.fill();
            ctx.stroke();
            ctx.strokeStyle = "rgba(245, 240, 232, 0.8)";
            ctx.lineWidth = 2;
            ctx.beginPath();
            ctx.moveTo(box.x + 22, box.y + 18);
            ctx.lineTo(box.x + box.width - 34, box.y + 18);
            ctx.stroke();
            ctx.strokeStyle = "rgba(26, 23, 20, 0.13)";
            ctx.lineWidth = 2.2;
            ctx.beginPath();
            ctx.moveTo(box.x + 28, box.y + box.height - 32);
            ctx.lineTo(box.x + box.width - 28, box.y + box.height - 32);
            ctx.stroke();
            ctx.strokeStyle = "rgba(63, 143, 138, 0.18)";
            ctx.lineWidth = 1.6;
            for (let x = box.x + 44; x < box.x + box.width - 40; x += 42) {
              ctx.beginPath();
              ctx.moveTo(x, box.y + box.height - 44);
              ctx.lineTo(x + 16, box.y + box.height - 44);
              ctx.stroke();
            }
            ctx.strokeStyle = "rgba(63, 143, 138, 0.28)";
            ctx.setLineDash([7, 8]);
            ctx.beginPath();
            ctx.moveTo(box.x + box.width + 18, box.y + 18);
            ctx.lineTo(box.x + box.width + 18, box.y + box.height - 18);
            ctx.stroke();
            ctx.setLineDash([]);
            ctx.restore();
          }

          function drawAgent(shake) {
            const foot = Math.sin(agent.phase * 2);
            const direction = agent.vx >= 0 ? 1 : -1;
            ctx.save();
            ctx.translate(shake, 0);
            ctx.fillStyle = "rgba(26, 23, 20, 0.16)";
            ctx.beginPath();
            ctx.ellipse(agent.x, agent.y + 12, 26, 5, 0, 0, Math.PI * 2);
            ctx.fill();
            ctx.strokeStyle = "rgba(26, 23, 20, 0.42)";
            ctx.lineWidth = 3;
            ctx.lineCap = "round";
            ctx.beginPath();
            ctx.moveTo(agent.x - 9, agent.y + 8);
            ctx.lineTo(agent.x - 14, agent.y + 14 + foot * 2);
            ctx.moveTo(agent.x + 9, agent.y + 8);
            ctx.lineTo(agent.x + 14, agent.y + 14 - foot * 2);
            ctx.stroke();
            ctx.fillStyle = "rgba(63, 143, 138, 0.9)";
            ctx.strokeStyle = "rgba(26, 23, 20, 0.36)";
            ctx.lineWidth = 2.4;
            ctx.beginPath();
            roundedRect(agent.x - 17, agent.y - 25, 34, 29, 9);
            ctx.fill();
            ctx.stroke();
            ctx.fillStyle = "rgba(245, 240, 232, 0.92)";
            ctx.beginPath();
            roundedRect(agent.x - 10, agent.y - 18, 20, 11, 4);
            ctx.fill();
            ctx.fillStyle = "rgba(26, 23, 20, 0.7)";
            ctx.beginPath();
            ctx.arc(agent.x - 4 + direction * 1.4, agent.y - 12.5, 1.8, 0, Math.PI * 2);
            ctx.arc(agent.x + 5 + direction * 1.4, agent.y - 12.5, 1.8, 0, Math.PI * 2);
            ctx.fill();
            ctx.strokeStyle = "rgba(26, 23, 20, 0.46)";
            ctx.lineWidth = 2;
            ctx.beginPath();
            ctx.moveTo(agent.x + 5, agent.y - 25);
            ctx.lineTo(agent.x + 12, agent.y - 34);
            ctx.stroke();
            ctx.fillStyle = "rgba(201, 123, 58, 0.78)";
            ctx.beginPath();
            ctx.arc(agent.x + 14, agent.y - 36, 3, 0, Math.PI * 2);
            ctx.fill();
            if (bump > 3) {
              const side = agent.x < box.x + box.width / 2 ? -1 : 1;
              const x = side < 0 ? box.x + 22 : box.x + box.width - 22;
              ctx.strokeStyle = `rgba(201, 123, 58, ${clamp(bump / 18, 0.18, 0.78)})`;
              ctx.lineWidth = 2.2;
              for (let i = 0; i < 3; i += 1) {
                ctx.beginPath();
                ctx.moveTo(x, agent.y - 10 + i * 8);
                ctx.lineTo(x - side * (12 + i * 4), agent.y - 16 + i * 9);
                ctx.stroke();
              }
            }
            ctx.restore();
          }

          function draw(now, forceStatic = false) {
            animationId = 0;
            const animate = !forceStatic && shouldAnimate();
            const delta = Math.min(64, now - last);
            last = now;
            if (animate) {
              const steps = Math.max(1, Math.round(delta / 16));
              for (let i = 0; i < steps; i += 1) step();
            }

            ctx.clearRect(0, 0, world.width, world.height);
            ctx.fillStyle = "#eee8de";
            ctx.fillRect(0, 0, world.width, world.height);
            drawProductionPanel();
            const shake = Math.sin(now / 28) * clamp(bump / 6, 0, 2.4);
            drawGlassBox(shake);
            drawAgent(shake);
            if (animate) scheduleFrame();
          }

          stage.addEventListener("click", () => {
            stopFrame();
            nudgeAgent(1.2);
            draw(performance.now(), true);
            updateFrameState();
          });
          stage.addEventListener("keydown", (event) => {
            if (event.key !== "Enter" && event.key !== " ") return;
            event.preventDefault();
            stopFrame();
            nudgeAgent(1.2);
            draw(performance.now(), true);
            updateFrameState();
          });

          resize();
          draw(performance.now(), true);
          window.addEventListener("resize", () => {
            stopFrame();
            resize();
            draw(performance.now(), true);
            updateFrameState();
          });

          if ("IntersectionObserver" in window) {
            const observer = new IntersectionObserver(([entry]) => {
              isIntersecting = Boolean(entry?.isIntersecting);
              updateFrameState();
            });
            observer.observe(stage);
          }

          document.addEventListener("visibilitychange", updateFrameState);
          updateFrameState();
        }

        document.querySelectorAll("[data-gate-stage]").forEach(initGateStage);
        document
          .querySelectorAll("[data-consequence-stage]")
          .forEach(initConsequenceStage);
        document.querySelectorAll("[data-sand-stage]").forEach(initSandStage);
        document
          .querySelectorAll("[data-sandbox-stage]")
          .forEach(initSandboxStage);
      })();
    </script>
  </body>
</html>
