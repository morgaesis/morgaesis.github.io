        const clamp = (value, min, max) => Math.min(max, Math.max(min, value));

        function initGateStage(stage) {
          const svg = stage.querySelector(".gate-map");
          if (!svg) return;
          const pulse = svg.querySelector("[data-gate-pulse]");
          const pulseRing = svg.querySelector("[data-gate-pulse-ring]");
          const trail = svg.querySelector("[data-pulse-trail]");
          const coverageFill = svg?.querySelector("[data-coverage-fill]");
          const blastFill = svg?.querySelector("[data-blast-fill]");
          const status = stage.querySelector(".gate-status");
          const scenarios = [
            { x: 476, y: 108 },
            { x: 418, y: 232 },
            { x: 486, y: 304 },
          ];
          const routeEnds = {
            plan: { x: 548, y: 86 },
            canary: { x: 538, y: 232 },
            abort: { x: 540, y: 304 },
          };
          let scenarioIndex = 0;
          let coverage = 0.82;
          let blast = 0.22;
          let route = "plan";
          let targetX = scenarios[0].x;
          let targetY = scenarios[0].y;
          let currentX = 86;
          let currentY = 248;
          let progress = 0;
          let pointerActive = false;
          let last = performance.now();
          let animationId = 0;
          let isIntersecting = !("IntersectionObserver" in window);
          const start = { x: 86, y: 248 };

          const labels = {
            plan:
              "Gate open: evidence is high and consequence is bounded, so approval can bind to the exact artifact.",
            canary:
              "Gate diverts: uncertainty goes through a canary bay with independent health signals before expansion.",
            abort:
              "Gate locked: weak evidence plus high consequence is a different request, not an approval click.",
          };

          function chooseRoute() {
            if (blast > 0.7 || (blast > 0.55 && coverage < 0.5)) return "abort";
            if (coverage > 0.66 && blast < 0.55) return "plan";
            return "canary";
          }

          function updateState() {
            route = chooseRoute();
            stage.dataset.route = route;
            if (status) status.textContent = labels[route];
            coverageFill?.setAttribute("width", `${Math.max(12, coverage * 150)}`);
            blastFill?.setAttribute("width", `${Math.max(10, blast * 150)}`);
          }

          function routePoint(amount) {
            const end = routeEnds[route] || routeEnds.canary;
            const t = amount % 1;
            const control =
              route === "plan"
                ? { x: 300, y: 118 }
                : route === "abort"
                  ? { x: 318, y: 300 }
                  : { x: 318, y: 226 };
            const oneMinus = 1 - t;
            return {
              x:
                oneMinus * oneMinus * start.x +
                2 * oneMinus * t * control.x +
                t * t * end.x,
              y:
                oneMinus * oneMinus * start.y +
                2 * oneMinus * t * control.y +
                t * t * end.y,
            };
          }

          function placePulse(now = performance.now()) {
            pulse?.setAttribute("cx", `${currentX}`);
            pulse?.setAttribute("cy", `${currentY}`);
            pulseRing?.setAttribute("cx", `${currentX}`);
            pulseRing?.setAttribute("cy", `${currentY}`);
            const ringSize =
              route === "abort"
                ? 16 + Math.sin(now / 90) * 3
                : 15 + Math.sin(now / 130) * 2;
            pulseRing?.setAttribute("r", `${ringSize}`);
            const controlX = start.x + (currentX - start.x) * 0.5;
            const controlY =
              route === "plan"
                ? Math.min(start.y, currentY) - 52
                : route === "abort"
                  ? Math.max(start.y, currentY) + 28
                  : (start.y + currentY) * 0.5 + 18;
            trail?.setAttribute(
              "d",
              `M${start.x.toFixed(1)} ${start.y.toFixed(1)} Q${controlX.toFixed(1)} ${controlY.toFixed(1)} ${currentX.toFixed(1)} ${currentY.toFixed(1)}`,
            );
          }

          function shouldAnimate() {
            return !reduceMotion && isIntersecting && !document.hidden;
          }

          function stopFrame() {
            if (animationId) cancelAnimationFrame(animationId);
            animationId = 0;
          }

          function scheduleFrame() {
            if (animationId || !shouldAnimate()) return;
            last = performance.now();
            animationId = requestAnimationFrame(frame);
          }

          function updateFrameState() {
            if (shouldAnimate()) {
              scheduleFrame();
            } else {
              stopFrame();
              if (pointerActive) {
                currentX = targetX;
                currentY = targetY;
              } else {
                const point = routePoint(0.68);
                currentX = point.x;
                currentY = point.y;
              }
              placePulse();
            }
          }

          function setTargetFromPoint(x, y) {
            targetX = clamp(x, 58, 590);
            targetY = clamp(y, 78, 312);
            coverage = clamp((targetX - 80) / 470, 0.05, 0.95);
            blast = clamp((targetY - 80) / 232, 0.05, 0.95);
            updateState();
          }

          function setFromPointer(event) {
            if (event.pointerType === "touch") return;
            const rect = stage.getBoundingClientRect();
            const x = ((event.clientX - rect.left) / rect.width) * 640;
            const y = ((event.clientY - rect.top) / rect.height) * 360;
            pointerActive = true;
            setTargetFromPoint(x, y);
            currentX = targetX;
            currentY = targetY;
            placePulse();
            updateFrameState();
          }

          function cycleScenario() {
            scenarioIndex = (scenarioIndex + 1) % scenarios.length;
            pointerActive = false;
            progress = 0;
            setTargetFromPoint(scenarios[scenarioIndex].x, scenarios[scenarioIndex].y);
          }

          stage.addEventListener("pointerenter", setFromPointer);
          stage.addEventListener("pointermove", setFromPointer);
          stage.addEventListener("pointerleave", () => {
            pointerActive = false;
            progress = 0;
            updateFrameState();
          });
          stage.addEventListener("click", () => {
            cycleScenario();
            updateFrameState();
          });
          stage.addEventListener("keydown", (event) => {
            if (event.key !== "Enter" && event.key !== " ") return;
            event.preventDefault();
            cycleScenario();
            updateFrameState();
          });

          function frame(now) {
            animationId = 0;
            if (!shouldAnimate()) {
              if (pointerActive) {
                currentX = targetX;
                currentY = targetY;
              } else {
                const point = routePoint(0.68);
                currentX = point.x;
                currentY = point.y;
              }
              placePulse(now);
              return;
            }
            const delta = Math.min(48, now - last);
            last = now;
            if (pointerActive) {
              currentX = targetX;
              currentY = targetY;
            } else {
