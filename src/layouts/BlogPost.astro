              updateFrameState();
            });
            observer.observe(stage);
          }

          document.addEventListener("visibilitychange", updateFrameState);
          updateFrameState();
        }

        function initConsequenceStage(stage) {
          const svg = stage.querySelector(".consequence-map");
          if (!svg) return;
          const token = svg.querySelector("[data-consequence-token]");
          const ring = svg.querySelector("[data-consequence-ring]");
          const trail = svg.querySelector("[data-consequence-trail]");
          const status = stage.querySelector(".consequence-status");
          const levels = [
            {
              key: "local",
              x: 116,
              label: "Local action: the token passes through a light gate.",
            },
            {
              key: "reversible",
              x: 252,
              label: "Reversible action: the gate half-opens and expects a recovery path.",
            },
            {
              key: "disruptive",
              x: 396,
              label: "Disruptive action: warning lights come on and rollout must be contained.",
            },
            {
              key: "irreversible",
              x: 486,
              label: "Irreversible action: the blast door stays shut; new approval required.",
            },
          ];
          let levelIndex = 0;
          let committedLevelIndex = 0;
          let currentX = 70;
          let targetX = levels[0].x;
          let last = performance.now();
          let animationId = 0;
          let isIntersecting = !("IntersectionObserver" in window);

          function setLevel(index) {
            levelIndex = clamp(index, 0, levels.length - 1);
            const level = levels[levelIndex];
            stage.dataset.level = level.key;
            targetX = level.x;
            if (status) status.textContent = level.label;
          }

          function setLevelFromPointer(event) {
            if (event.pointerType === "touch") return;
            const rect = stage.getBoundingClientRect();
            const x = ((event.clientX - rect.left) / rect.width) * 640;
            const score = clamp((x - 60) / 520, 0, 0.999);
            setLevel(Math.floor(score * levels.length));
            updateFrameState();
          }

          function cycleLevel() {
            committedLevelIndex = (committedLevelIndex + 1) % levels.length;
            setLevel(committedLevelIndex);
            updateFrameState();
          }

          function placeToken(now = performance.now()) {
            const y = 232;
            const pulse = 16 + Math.sin(now / (levelIndex >= 2 ? 76 : 130)) * (levelIndex >= 2 ? 4 : 2);
            token?.setAttribute("cx", `${currentX.toFixed(1)}`);
            token?.setAttribute("cy", `${y}`);
            ring?.setAttribute("cx", `${currentX.toFixed(1)}`);
            ring?.setAttribute("cy", `${y}`);
            ring?.setAttribute("r", `${pulse.toFixed(1)}`);
            trail?.setAttribute("d", `M48 232 H${currentX.toFixed(1)}`);
          }

          function shouldAnimate() {
            return !reduceMotion && isIntersecting && !document.hidden;
          }

          function stopFrame() {
            if (animationId) cancelAnimationFrame(animationId);
            animationId = 0;
          }

          function scheduleFrame() {
            if (animationId || !shouldAnimate()) return;
            last = performance.now();
            animationId = requestAnimationFrame(frame);
          }

          function updateFrameState() {
            if (shouldAnimate()) {
              scheduleFrame();
            } else {
              stopFrame();
              currentX = targetX;
              placeToken();
            }
          }

          function frame(now) {
            animationId = 0;
            if (!shouldAnimate()) {
              currentX = targetX;
              placeToken(now);
              return;
            }
            const delta = Math.min(48, now - last);
            last = now;
            const pull = clamp(delta / 130, 0.1, 0.3);
            currentX += (targetX - currentX) * pull;
            placeToken(now);
            scheduleFrame();
