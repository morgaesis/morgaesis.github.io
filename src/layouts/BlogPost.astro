          stage.addEventListener("pointermove", setLevelFromPointer);
          stage.addEventListener("pointerleave", () => {
            setLevel(committedLevelIndex);
            updateFrameState();
          });
          stage.addEventListener("click", () => {
            cycleLevel();
          });
          stage.addEventListener("keydown", (event) => {
            if (event.key !== "Enter" && event.key !== " ") return;
            event.preventDefault();
            cycleLevel();
          });

          setLevel(0);
          placeToken();

          if ("IntersectionObserver" in window) {
            const observer = new IntersectionObserver(([entry]) => {
              isIntersecting = Boolean(entry?.isIntersecting);
              updateFrameState();
            });
            observer.observe(stage);
          }

          document.addEventListener("visibilitychange", updateFrameState);
          updateFrameState();
        }

        function initSandStage(stage) {
          const canvas = stage.querySelector("canvas");
          const ctx = canvas?.getContext("2d");
          const modeLabel = stage.querySelector(".sand-mode");
          if (!canvas || !ctx) return;

          const world = { width: 540, height: 360 };
          let mode = "self";
          let particles = [];
          let caught = 0;
          let impact = 0;
          let last = performance.now();
          let animationId = 0;
          let isIntersecting = !("IntersectionObserver" in window);

          function resize() {
            const rect = stage.getBoundingClientRect();
            const width = Math.max(320, rect.width);
            const height = width * (world.height / world.width);
            const scale = window.devicePixelRatio || 1;
            canvas.style.height = `${height}px`;
            canvas.width = Math.round(width * scale);
            canvas.height = Math.round(height * scale);
            ctx.setTransform(
              canvas.width / world.width,
              0,
              0,
              canvas.height / world.height,
              0,
              0,
            );
          }

          function roundedRect(x, y, width, height, radius) {
            const r = Math.min(radius, width / 2, height / 2);
            ctx.moveTo(x + r, y);
            ctx.lineTo(x + width - r, y);
            ctx.quadraticCurveTo(x + width, y, x + width, y + r);
            ctx.lineTo(x + width, y + height - r);
            ctx.quadraticCurveTo(x + width, y + height, x + width - r, y + height);
            ctx.lineTo(x + r, y + height);
            ctx.quadraticCurveTo(x, y + height, x, y + height - r);
            ctx.lineTo(x, y + r);
            ctx.quadraticCurveTo(x, y, x + r, y);
          }

          function makeParticle(seed = 0) {
            const spread = Math.sin(seed * 9.17) * 0.5 + 0.5;
            const bad = Math.random() < (mode === "self" ? 0.62 : 0.5);
            const lane = -2 + Math.floor(Math.random() * 5);
            return {
              bad,
              caught: false,
              lane,
              settled: false,
              stopX: 0,
              stopY: 0,
              x: 92 + spread * 52,
              y: 112 + lane * 5 + Math.random() * 12,
              vx: (mode === "self" ? 1.85 : 1.42) + Math.random() * 0.7,
              vy: 0,
              r: 1.7 + Math.random() * 1.7,
              life: 0,
              color: bad
                ? `rgba(${176 + Math.random() * 46}, ${54 + Math.random() * 30}, ${46 + Math.random() * 28}, 0.9)`
                : `rgba(${62 + Math.random() * 34}, ${132 + Math.random() * 38}, ${122 + Math.random() * 34}, 0.86)`,
            };
          }

          function seedParticles() {
            particles = [];
            for (let i = 0; i < 64; i += 1) {
              const particle = makeParticle(i);
              particle.x += Math.random() * 145;
              particle.y = streamY(particle, particle.x) + Math.random() * 10 - 5;
              particles.push(particle);
