---
interface Props {
  title: string;
  date: Date;
  description?: string;
}

const { title, date, description } = Astro.props;
const formatted = date.toLocaleDateString("en-GB", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Mörgæsis</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Mörgæsis"
      href="/rss.xml"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif&family=DM+Sans:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <main>
      <nav class="back">
        <a href="/blog">&larr; blog</a>
      </nav>

      <article>
        <header>
          <h1>{title}</h1>
          <time datetime={date.toISOString()}>{formatted}</time>
        </header>
        <div class="prose">
          <slot />
        </div>
      </article>
    </main>

    <style>
      :root {
        --cream: #f5f0e8;
        --ink: #1a1714;
        --mid: #6b6259;
        --faint: #c8bfb2;
        --rule: #d9d0c3;
        --amber: #c97b3a;
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html {
        font-size: 18px;
      }

      body {
        font-family: "DM Sans", sans-serif;
        font-weight: 400;
        background: var(--cream);
        color: var(--ink);
        line-height: 1.7;
        min-height: 100vh;
        padding: 0 1.5rem;
        -webkit-font-smoothing: antialiased;
      }

      main {
        max-width: 540px;
        margin: 0 auto;
        padding: 8vh 0 8vh;
      }

      .back {
        font-size: 0.82rem;
        margin-bottom: 3rem;
      }

      .back a {
        color: var(--faint);
        text-decoration: none;
        border-bottom: none;
        transition: color 0.2s;
      }

      .back a:hover {
        color: var(--ink);
      }

      article header {
        margin-bottom: 2.5rem;
      }

      h1 {
        font-family: "Instrument Serif", serif;
        font-weight: 400;
        font-size: 2.4rem;
        letter-spacing: -0.03em;
        line-height: 1.15;
        margin-bottom: 0.5rem;
      }

      time {
        font-size: 0.78rem;
        color: var(--faint);
        letter-spacing: 0.02em;
      }

      .prose :global(h2) {
        font-family: "Instrument Serif", serif;
        font-weight: 400;
        font-size: 1.5rem;
        margin-top: 2.5rem;
        margin-bottom: 0.8rem;
      }

      .prose :global(h3) {
        font-family: "DM Sans", sans-serif;
        font-weight: 500;
        font-size: 1rem;
        margin-top: 2rem;
        margin-bottom: 0.6rem;
      }

      .prose :global(p) {
        margin-bottom: 1.2rem;
        color: var(--ink);
      }

      .prose :global(a) {
        color: var(--ink);
        text-decoration: none;
        border-bottom: 1.5px solid var(--rule);
        transition: border-color 0.2s;
      }

      .prose :global(a:hover) {
        border-bottom-color: var(--ink);
      }

      .prose :global(ul),
      .prose :global(ol) {
        margin-bottom: 1.2rem;
        padding-left: 1.2rem;
      }

      .prose :global(li) {
        margin-bottom: 0.4rem;
      }

      .prose :global(blockquote) {
        border-left: 3px solid var(--amber);
        padding-left: 1rem;
        margin: 1.5rem 0;
        color: var(--mid);
        font-style: italic;
      }

      .prose :global(code) {
        font-size: 0.88em;
        background: #e8e3db;
        padding: 0.15em 0.4em;
        border-radius: 3px;
      }

      .prose :global(pre) {
        background: var(--ink);
        color: var(--cream);
        padding: 1.2rem;
        border-radius: 6px;
        overflow-x: auto;
        margin-bottom: 1.5rem;
        font-size: 0.85rem;
        line-height: 1.5;
      }

      .prose :global(pre code) {
        background: none;
        padding: 0;
        border-radius: 0;
      }

      .prose :global(hr) {
        border: none;
        border-top: 1px solid var(--rule);
        margin: 2rem 0;
      }

      .prose :global(img) {
        max-width: 100%;
        border-radius: 6px;
        margin: 1.5rem 0;
      }

      @media (max-width: 480px) {
        html {
          font-size: 16px;
        }
        main {
          padding: 6vh 0 6vh;
        }
        h1 {
          font-size: 1.8rem;
        }
      }
    </style>
  </body>
</html>
