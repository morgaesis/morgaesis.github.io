          function scheduleFrame() {
            if (animationId || !shouldAnimate()) return;
            last = performance.now();
            animationId = requestAnimationFrame(frame);
          }

          function updateFrameState() {
            if (shouldAnimate()) {
              scheduleFrame();
            } else {
              stopFrame();
              placeTokens(performance.now());
            }
          }

          function placeTokens(now = performance.now()) {
            const badPath = modes[mode].path;
            const badPoint = pointOn(badPath, progress);
            setToken(badToken, badPoint);
            setToken(ring, badPoint);
            const pulse = 15 + Math.sin(now / (mode === "self" ? 82 : 120)) * 2.4;
            ring?.setAttribute("r", `${pulse.toFixed(1)}`);
            if (mode === "independent") {
              const goodPoint = pointOn(passRoute, (progress + 0.42) % 1);
              setToken(goodToken, goodPoint);
            } else {
              setToken(goodToken, { x: 42, y: 218 });
            }
            impact?.setAttribute("r", `${(mode === "self" ? 28 + Math.sin(now / 95) * 5 : 20).toFixed(1)}`);
          }

          function frame(now) {
            animationId = 0;
            if (!shouldAnimate()) {
              placeTokens(now);
              return;
            }
            const delta = Math.min(48, now - last);
            last = now;
            if (now >= nextAutoCycle) {
              setMode(mode === "self" ? "independent" : "self");
            }
            progress = (progress + delta / (mode === "self" ? 3200 : 3600)) % 1;
            placeTokens(now);
            scheduleFrame();
          }

          stage.addEventListener("click", () => {
            stopFrame();
            setMode(mode === "self" ? "independent" : "self");
            placeTokens();
            updateFrameState();
          });
          stage.addEventListener("keydown", (event) => {
            if (event.key !== "Enter" && event.key !== " ") return;
            event.preventDefault();
            stopFrame();
            setMode(mode === "self" ? "independent" : "self");
            placeTokens();
            updateFrameState();
          });

          setMode("self");
          placeTokens();

          if ("IntersectionObserver" in window) {
            const observer = new IntersectionObserver(([entry]) => {
              isIntersecting = Boolean(entry?.isIntersecting);
              updateFrameState();
            });
            observer.observe(stage);
          }

          document.addEventListener("visibilitychange", updateFrameState);
          updateFrameState();
        }

        function initSandboxStage(stage) {
          const canvas = stage.querySelector("canvas");
          const ctx = canvas?.getContext("2d");
          const modeLabel = stage.querySelector(".sandbox-mode");
          if (!canvas || !ctx) return;

          const world = { width: 540, height: 360 };
          const box = { x: 88, y: 70, width: 330, height: 214 };
          const agent = {
            x: 226,
            y: box.y + box.height - 38,
            vx: 1.55,
            width: 34,
            height: 30,
            phase: 0,
          };
          let bump = 0;
          let last = performance.now();
          let animationId = 0;
          let isIntersecting = !("IntersectionObserver" in window);

          function resize() {
            const rect = stage.getBoundingClientRect();
            const width = Math.max(320, rect.width);
            const height = width * (world.height / world.width);
            const scale = window.devicePixelRatio || 1;
            canvas.style.height = `${height}px`;
            canvas.width = Math.round(width * scale);
            canvas.height = Math.round(height * scale);
            ctx.setTransform(
              canvas.width / world.width,
              0,
              0,
              canvas.height / world.height,
              0,
              0,
            );
          }

          function roundedRect(x, y, width, height, radius) {
            const r = Math.min(radius, width / 2, height / 2);
            ctx.moveTo(x + r, y);
            ctx.lineTo(x + width - r, y);
            ctx.quadraticCurveTo(x + width, y, x + width, y + r);
            ctx.lineTo(x + width, y + height - r);
            ctx.quadraticCurveTo(x + width, y + height, x + width - r, y + height);
            ctx.lineTo(x + r, y + height);
            ctx.quadraticCurveTo(x, y + height, x, y + height - r);
            ctx.lineTo(x, y + r);
            ctx.quadraticCurveTo(x, y, x + r, y);
          }

          function nudgeAgent(strength = 1) {
            const direction = Math.random() > 0.5 ? 1 : -1;
            agent.vx = direction * (1.8 + Math.random() * 0.75) * strength;
            bump = Math.max(bump, 12 * strength);
            if (modeLabel) {
              modeLabel.textContent = "contained exploration: the boundary absorbs the bump";
            }
          }

          function shouldAnimate() {
            return !reduceMotion && isIntersecting && !document.hidden;
          }

          function stopFrame() {
            if (animationId) cancelAnimationFrame(animationId);
            animationId = 0;
          }

          function scheduleFrame() {
            if (animationId || !shouldAnimate()) return;
            last = performance.now();
            animationId = requestAnimationFrame(draw);
          }

          function updateFrameState() {
            if (shouldAnimate()) {
              scheduleFrame();
            } else {
              stopFrame();
              draw(performance.now(), true);
            }
          }

          function step() {
            const floor = box.y + box.height - 34;
            agent.phase += Math.abs(agent.vx) * 0.1;
            agent.x += agent.vx;
            agent.vx += Math.sin(performance.now() / 760) * 0.018;
            agent.vx = clamp(agent.vx, -2.45, 2.45);
            agent.y = floor + Math.sin(agent.phase * 2) * 1.4;

            const minX = box.x + agent.width / 2 + 12;
            const maxX = box.x + box.width - agent.width / 2 - 12;
            if (agent.x < minX || agent.x > maxX) {
              agent.x = clamp(agent.x, minX, maxX);
              agent.vx *= -0.94;
              bump = 14;
            }
            bump *= 0.9;
          }

          function drawProductionPanel() {
            ctx.save();
            ctx.fillStyle = "rgba(245, 240, 232, 0.64)";
            ctx.strokeStyle = "rgba(26, 23, 20, 0.18)";
            ctx.lineWidth = 2;
            ctx.beginPath();
            roundedRect(446, 112, 54, 120, 8);
            ctx.fill();
            ctx.stroke();
            ctx.strokeStyle = "rgba(26, 23, 20, 0.22)";
            for (let y = 134; y < 210; y += 22) {
              ctx.beginPath();
              ctx.moveTo(458, y);
              ctx.lineTo(488, y);
              ctx.stroke();
            }
            ctx.fillStyle = "rgba(63, 143, 138, 0.56)";
            ctx.beginPath();
            ctx.arc(488, 122, 4, 0, Math.PI * 2);
            ctx.fill();
            ctx.restore();
          }

          function drawGlassBox(shake) {
            ctx.save();
            ctx.translate(shake, 0);
            ctx.fillStyle = "rgba(170, 209, 210, 0.16)";
            ctx.strokeStyle = "rgba(63, 143, 138, 0.62)";
            ctx.lineWidth = 4;
            ctx.beginPath();
            roundedRect(box.x, box.y, box.width, box.height, 12);
            ctx.fill();
            ctx.stroke();
            ctx.strokeStyle = "rgba(245, 240, 232, 0.8)";
            ctx.lineWidth = 2;
            ctx.beginPath();
            ctx.moveTo(box.x + 22, box.y + 18);
            ctx.lineTo(box.x + box.width - 34, box.y + 18);
            ctx.stroke();
            ctx.strokeStyle = "rgba(26, 23, 20, 0.13)";
            ctx.lineWidth = 2.2;
            ctx.beginPath();
            ctx.moveTo(box.x + 28, box.y + box.height - 32);
            ctx.lineTo(box.x + box.width - 28, box.y + box.height - 32);
            ctx.stroke();
            ctx.strokeStyle = "rgba(63, 143, 138, 0.18)";
            ctx.lineWidth = 1.6;
            for (let x = box.x + 44; x < box.x + box.width - 40; x += 42) {
              ctx.beginPath();
              ctx.moveTo(x, box.y + box.height - 44);
              ctx.lineTo(x + 16, box.y + box.height - 44);
              ctx.stroke();
            }
            ctx.strokeStyle = "rgba(63, 143, 138, 0.28)";
            ctx.setLineDash([7, 8]);
            ctx.beginPath();
            ctx.moveTo(box.x + box.width + 18, box.y + 18);
            ctx.lineTo(box.x + box.width + 18, box.y + box.height - 18);
            ctx.stroke();
            ctx.setLineDash([]);
            ctx.restore();
          }

          function drawAgent(shake) {
            const foot = Math.sin(agent.phase * 2);
            const direction = agent.vx >= 0 ? 1 : -1;
            ctx.save();
            ctx.translate(shake, 0);
            ctx.fillStyle = "rgba(26, 23, 20, 0.16)";
            ctx.beginPath();
            ctx.ellipse(agent.x, agent.y + 12, 26, 5, 0, 0, Math.PI * 2);
            ctx.fill();
            ctx.strokeStyle = "rgba(26, 23, 20, 0.42)";
            ctx.lineWidth = 3;
            ctx.lineCap = "round";
            ctx.beginPath();
            ctx.moveTo(agent.x - 9, agent.y + 8);
            ctx.lineTo(agent.x - 14, agent.y + 14 + foot * 2);
            ctx.moveTo(agent.x + 9, agent.y + 8);
            ctx.lineTo(agent.x + 14, agent.y + 14 - foot * 2);
            ctx.stroke();
            ctx.fillStyle = "rgba(63, 143, 138, 0.9)";
            ctx.strokeStyle = "rgba(26, 23, 20, 0.36)";
            ctx.lineWidth = 2.4;
            ctx.beginPath();
            roundedRect(agent.x - 17, agent.y - 25, 34, 29, 9);
            ctx.fill();
            ctx.stroke();
            ctx.fillStyle = "rgba(245, 240, 232, 0.92)";
            ctx.beginPath();
            roundedRect(agent.x - 10, agent.y - 18, 20, 11, 4);
            ctx.fill();
            ctx.fillStyle = "rgba(26, 23, 20, 0.7)";
            ctx.beginPath();
            ctx.arc(agent.x - 4 + direction * 1.4, agent.y - 12.5, 1.8, 0, Math.PI * 2);
            ctx.arc(agent.x + 5 + direction * 1.4, agent.y - 12.5, 1.8, 0, Math.PI * 2);
            ctx.fill();
            ctx.strokeStyle = "rgba(26, 23, 20, 0.46)";
            ctx.lineWidth = 2;
            ctx.beginPath();
            ctx.moveTo(agent.x + 5, agent.y - 25);
            ctx.lineTo(agent.x + 12, agent.y - 34);
            ctx.stroke();
            ctx.fillStyle = "rgba(201, 123, 58, 0.78)";
            ctx.beginPath();
            ctx.arc(agent.x + 14, agent.y - 36, 3, 0, Math.PI * 2);
            ctx.fill();
            if (bump > 3) {
              const side = agent.x < box.x + box.width / 2 ? -1 : 1;
              const x = side < 0 ? box.x + 22 : box.x + box.width - 22;
              ctx.strokeStyle = `rgba(201, 123, 58, ${clamp(bump / 18, 0.18, 0.78)})`;
              ctx.lineWidth = 2.2;
              for (let i = 0; i < 3; i += 1) {
                ctx.beginPath();
                ctx.moveTo(x, agent.y - 10 + i * 8);
                ctx.lineTo(x - side * (12 + i * 4), agent.y - 16 + i * 9);
                ctx.stroke();
              }
            }
            ctx.restore();
          }

          function draw(now, forceStatic = false) {
            animationId = 0;
            const animate = !forceStatic && shouldAnimate();
            const delta = Math.min(64, now - last);
            last = now;
            if (animate) {
              const steps = Math.max(1, Math.round(delta / 16));
              for (let i = 0; i < steps; i += 1) step();
            }

            ctx.clearRect(0, 0, world.width, world.height);
            ctx.fillStyle = "#eee8de";
            ctx.fillRect(0, 0, world.width, world.height);
            drawProductionPanel();
            const shake = Math.sin(now / 28) * clamp(bump / 6, 0, 2.4);
            drawGlassBox(shake);
            drawAgent(shake);
            if (animate) scheduleFrame();
          }

          stage.addEventListener("click", () => {
            stopFrame();
            nudgeAgent(1.2);
            draw(performance.now(), true);
            updateFrameState();
          });
          stage.addEventListener("keydown", (event) => {
            if (event.key !== "Enter" && event.key !== " ") return;
            event.preventDefault();
            stopFrame();
            nudgeAgent(1.2);
            draw(performance.now(), true);
            updateFrameState();
          });

          resize();
          draw(performance.now(), true);
          window.addEventListener("resize", () => {
            stopFrame();
            resize();
            draw(performance.now(), true);
            updateFrameState();
          });

          if ("IntersectionObserver" in window) {
            const observer = new IntersectionObserver(([entry]) => {
              isIntersecting = Boolean(entry?.isIntersecting);
              updateFrameState();
            });
            observer.observe(stage);
          }

          document.addEventListener("visibilitychange", updateFrameState);
          updateFrameState();
        }

        document.querySelectorAll("[data-gate-stage]").forEach(initGateStage);
        document
          .querySelectorAll("[data-consequence-stage]")
          .forEach(initConsequenceStage);
        document.querySelectorAll("[data-sand-stage]").forEach(initSandStage);
        document
          .querySelectorAll("[data-sandbox-stage]")
          .forEach(initSandboxStage);
      })();
    </script>
  </body>
</html>
